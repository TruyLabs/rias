agent:
  name: kai           # Display name for the AI agent
  user_name: Kyle     # Your name — used in prompts and learning extraction

provider: claude
providers:
  claude:
    auth: api_key
    model: claude-sonnet-4-6-20250514
    # base_url: https://api.anthropic.com  # optional: custom endpoint
    # timeout_sec: 120                     # optional: HTTP timeout (default: 120)
  openai:
    auth: api_key
    model: gpt-4o
    # base_url: https://api.openai.com     # optional: custom endpoint (e.g. Ollama)
    # timeout_sec: 120                     # optional: HTTP timeout (default: 120)
brain:
  path: ~/.kai/brain  # default; set to any path you prefer
  max_context_files: 5
  embeddings:
    provider: ""  # "ollama", "lsi", or "" (auto: tries ollama, falls back to lsi)
    ollama:
      url: http://localhost:11434    # Ollama API URL
      model: nomic-embed-text       # Embedding model (also: mxbai-embed-large, all-minilm)
  sync:
    git:
      enabled: false
      # remote: git@github.com:user/kai-brain.git  # optional: push/pull to remote
      # branch: main                                # default: main
sessions_path: ~/.kai/sessions
server:
  listen_addr: 0.0.0.0:8080
  dashboard_pin: ""  # PIN lock for dashboard (empty = no auth)

# Modules pull external data into the brain on demand via 'kai module run'.
# Run 'kai module list' to see all available modules.
# Note: ${ENV_VAR} references must be set in your environment before running kai.
modules:
  - name: github_prs
    enabled: false
    config:
      token: ${GITHUB_TOKEN}        # GitHub personal access token
      repos:
        - owner/repo               # list of owner/repo to fetch PRs from
      state: open                  # open | closed | all (default: open)
      limit: 20                    # max PRs per repo (default: 20)

  - name: google_sheets
    enabled: false
    config:
      api_key: ${GOOGLE_API_KEY}   # Google API key (sheet must be publicly accessible)
      spreadsheet_id: ""           # ID from the sheet URL
      range: "Sheet1!A:Z"          # cell range to read (default: Sheet1!A:Z)
      category: knowledge          # brain category: knowledge | decisions | identity | opinions | style
      topic: my-sheet              # brain file slug (used as filename)
